# Encryption key for stored credentials (min 32 chars, generate with: openssl rand -hex 32)
SPHERE86_SECRET=change-me-in-production-use-a-random-64-char-string

# SQLite database path (matches app default)
DATABASE_URL=file:./data/sphere86/config/sphere86.db

# Local runtime root inside container/workspace (no SMB/NFS share required)
SPHERE86_DATA_ROOT=./data/sphere86

# Standard 86Box paths used by Sphere86 publish/deploy flow
BOX86_BINARY_PATH=/usr/local/bin/86Box
BOX86_CONFIG_BASE_PATH=./data/86box
BOX86_ROMS_PATH=/opt/86box/roms

# Octal modes for VM dirs/files under SPHERE86_DATA_ROOT/vms/<uuid>/ (panel often runs as root in Docker;
# streaming host user must be able to write). Defaults: 777 dirs, 666 files.
# SHARE_VM_DIR_MODE=777
# SHARE_VM_FILE_MODE=666
